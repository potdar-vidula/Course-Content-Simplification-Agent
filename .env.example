# ─────────────────────────────────────────────────────────────────────────────
# IBM watsonx.ai Credentials
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# Get your Project ID from your watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai endpoint URL (region-specific)
# US South:  https://us-south.ml.cloud.ibm.com
# EU DE:     https://eu-de.ml.cloud.ibm.com
# EU GB:     https://eu-gb.ml.cloud.ibm.com
# JP Tok:    https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─────────────────────────────────────────────────────────────────────────────
# IBM Granite Model Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Recommended models:
#   ibm/granite-13b-instruct-v2   (default – best for instruction-following)
#   ibm/granite-3-8b-instruct     (fast, efficient)
#   ibm/granite-20b-multilingual  (multilingual support)
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# Maximum tokens to generate per response (256–2048)
MAX_NEW_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# Flask Application Settings
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-string

# Set to "true" to enable Flask debug mode (NEVER in production)
FLASK_DEBUG=false

# Port the app listens on (Heroku sets this automatically)
PORT=5000

